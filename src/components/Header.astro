---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="logo">
			<a href="/">{SITE_TITLE}</a>
		</h2>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}

	nav {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		padding: 0.5rem 0;
	}

	.logo {
		margin: 0;
		font-size: 1em;
		justify-self: start;
	}

	.logo a {
		text-decoration: none;
		color: var(--black);
	}

	.internal-links {
		display: flex;
		gap: 1rem;
		justify-self: center;
	}

	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}

	nav a.active {
		border-bottom-color: var(--accent);
	}

	/* Responsive */
	@media (max-width: 720px) {
		nav {
			grid-template-columns: 1fr;
			row-gap: 0.5rem;
			text-align: center;
		}

		.logo,
		.internal-links {
			justify-self: center;
		}
	}
</style>